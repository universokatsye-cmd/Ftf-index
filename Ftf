<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <title>FTF Values - Custom Edition</title>

    <meta name="mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="FTF Values">
    <meta name="apple-mobile-web-app-title" content="FTF Values">
    <meta name="theme-color" content="#0f1117">
    <meta name="msapplication-navbutton-color" content="#0f1117">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    
    <link rel="icon" sizes="192x192" href="https://via.placeholder.com/192">
    <link rel="apple-touch-icon" href="https://via.placeholder.com/192">
    
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>

    <style>
        /* Base & Colors Reset */
        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            background-color: #0f1117;
            color: #ffffff;
            font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
            padding: 12px;
            -webkit-font-smoothing: antialiased;
        }

        /* Top Header Navigation style FTF */
        .ftf-header {
            max-width: 1300px;
            margin: 0 auto 12px auto;
            background: #161920;
            border-bottom: 1px solid #232836;
            padding: 10px 16px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-radius: 6px;
        }

        .ftf-header-logo {
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .ftf-header-logo h1 {
            font-size: 16px;
            font-weight: 800;
            letter-spacing: 0.5px;
            text-transform: uppercase;
            color: #ffffff;
        }

        .ftf-header-logo span {
            color: #ffb830;
        }

        .ftf-nav-links {
            display: flex;
            gap: 16px;
        }

        .ftf-nav-item {
            font-size: 13px;
            font-weight: 600;
            color: #94a3b8;
            cursor: pointer;
            transition: color 0.2s;
            text-transform: uppercase;
        }

        .ftf-nav-item.active {
            color: #ffb830;
        }

        /* Controls Toggle Area */
        .toolbar-container {
            max-width: 1300px;
            margin: 0 auto 12px auto;
            background: #161920;
            padding: 8px 12px;
            border-radius: 6px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 8px;
            flex-wrap: wrap;
            border: 1px solid #1e222b;
        }

        .ui-btn {
            background: #222733;
            color: #cbd5e1;
            font-size: 12px;
            font-weight: 600;
            border: 1px solid #2d3445;
            padding: 6px 12px;
            border-radius: 4px;
            cursor: pointer;
            transition: all 0.2s;
        }

        .ui-btn:hover {
            background: #2d3445;
            color: #fff;
        }

        .btn-salvar-galeria {
            background: #ffb830;
            color: #000;
            border: none;
        }

        .btn-salvar-galeria:hover {
            background: #e6a422;
            color: #000;
        }

        /* Dashboard Overview Area style FTF */
        .ftf-dashboard {
            max-width: 1300px;
            margin: 0 auto 12px auto;
            background: #161920;
            border-radius: 6px;
            padding: 12px 16px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 12px;
            border: 1px solid #1e222b;
        }

        .ftf-dash-left {
            display: flex;
            align-items: center;
            gap: 20px;
        }

        .ftf-dash-block {
            display: flex;
            flex-direction: column;
        }

        .ftf-dash-label {
            font-size: 10px;
            color: #64748b;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 2px;
        }

        .ftf-dash-value {
            font-size: 18px;
            font-weight: 800;
            color: #ffffff;
        }

        .ftf-dash-value span {
            color: #ffb830;
        }

        .dash-date-input {
            background: #0f1117;
            color: #94a3b8;
            border: 1px solid #232836;
            padding: 4px 8px;
            border-radius: 4px;
            font-size: 11px;
            outline: none;
            width: 120px;
            text-align: center;
            font-weight: 600;
        }

        /* Main Search & Sorting Inputs Row */
        .search-wrapper {
            max-width: 1300px;
            margin: 0 auto 12px auto;
            display: flex;
            gap: 8px;
            width: 100%;
        }

        .input-style {
            background: #161920;
            color: #fff;
            border: 1px solid #232836;
            border-radius: 4px;
            padding: 8px 12px;
            font-size: 13px;
            outline: none;
            transition: border-color 0.2s;
        }

        .input-style:focus {
            border-color: #ffb830;
        }

        #barraPesquisa {
            flex: 1;
        }

        #ordenacaoLista {
            width: 200px;
            font-weight: 600;
            cursor: pointer;
            color: #94a3b8;
        }

        /* Filter Tab Buttons Style */
        .btn-aba-container, .event-filter-wrapper, .subtabs-container {
            max-width: 1300px;
            margin: 0 auto 8px auto;
            background: #161920;
            padding: 6px;
            border-radius: 6px;
            display: flex;
            flex-wrap: wrap;
            gap: 4px;
            align-items: center;
            border: 1px solid #1e222b;
        }

        .btn-aba, .btn-subtab {
            background: transparent;
            color: #94a3b8;
            border: none;
            padding: 6px 12px;
            border-radius: 4px;
            cursor: pointer;
            font-weight: 600;
            font-size: 12px;
            transition: all 0.15s;
        }

        .btn-aba:hover, .btn-subtab:hover {
            color: #fff;
            background: #202633;
        }

        .btn-aba.active, .btn-subtab.active {
            background: #ffb830;
            color: #000 !important;
            font-weight: 700;
        }

        .event-filter-wrapper label {
            font-size: 11px;
            font-weight: 700;
            color: #64748b;
            text-transform: uppercase;
            padding-left: 6px;
        }

        .select-event {
            background: #0f1117;
            color: #fff;
            border: 1px solid #232836;
            padding: 4px 8px;
            border-radius: 4px;
            font-size: 12px;
            outline: none;
            cursor: pointer;
        }

        /* Event Filter Buttons (fixed: this is the class actually used in the HTML) */
        .event-filter-container {
            max-width: 1300px;
            margin: 0 auto 8px auto;
            background: #161920;
            padding: 6px;
            border-radius: 6px;
            display: flex;
            flex-wrap: wrap;
            gap: 4px;
            align-items: center;
            border: 1px solid #1e222b;
        }

        .event-btn {
            background: transparent;
            color: #94a3b8;
            border: 1px solid #232836;
            border-radius: 4px;
            padding: 4px 10px;
            cursor: pointer;
            font-size: 11px;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 4px;
            transition: all 0.15s;
        }

        .event-btn img {
            width: 18px;
            height: 18px;
            object-fit: contain;
            display: block;
        }

        .event-btn:hover {
            background: #202633;
            color: #fff;
        }

        .event-btn.active {
            background: #ffb830;
            border-color: #ffb830;
            color: #000;
            font-weight: 700;
        }

        /* Item Creator Layout Panel Form */
        #criador-form {
            background-color: #161920;
            padding: 14px;
            border-radius: 6px;
            border: 1px solid #232836;
            max-width: 1300px;
            margin: 0 auto 12px auto;
        }

        .form-tabs {
            display: flex;
            gap: 4px;
            margin-bottom: 12px;
            border-bottom: 1px solid #232836;
            padding-bottom: 6px;
        }

        .form-tab-btn {
            background: transparent;
            color: #94a3b8;
            border: none;
            padding: 6px 12px;
            cursor: pointer;
            font-weight: 600;
            font-size: 12px;
            border-radius: 4px;
        }

        .form-tab-btn.active {
            background: #222733;
            color: #ffb830;
        }

        .form-section h3 {
            color: #fff;
            font-size: 14px;
            margin-bottom: 10px;
            font-weight: 700;
        }

        .form-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 8px;
        }

        .form-group {
            display: flex;
            flex-direction: column;
        }

        .form-label {
            color: #64748b;
            font-size: 11px;
            margin-bottom: 4px;
            font-weight: 700;
            text-transform: uppercase;
        }

        .form-input-full {
            width: 100%;
        }

        .btn-submit {
            grid-column: 1 / -1;
            padding: 10px;
            background: #ffb830;
            color: black;
            border: none;
            border-radius: 4px;
            cursor: pointer;
            font-weight: 700;
            font-size: 13px;
            margin-top: 6px;
            transition: background 0.2s;
        }

        .btn-submit:hover {
            background: #e6a422;
        }

        /* Section Category Title Header Layout */
        #titulo-secao {
            max-width: 1300px;
            margin: 16px auto 10px auto;
            color: #fff;
            font-size: 13px;
            font-weight: 800;
            letter-spacing: 0.5px;
            text-transform: uppercase;
            display: flex;
            align-items: center;
            gap: 6px;
        }

        #titulo-secao::before {
            content: '';
            display: inline-block;
            width: 3px;
            height: 14px;
            background: #ffb830;
            border-radius: 2px;
        }

        /* Strict FTF Cards Container System Grid */
        #container-cards {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
            gap: 8px;
            max-width: 1300px;
            margin: 0 auto;
            width: 100%;
        }

        /* Strict Official FTF Card UI Style Concept */
        .ftf-item-card {
            background-color: #14171f;
            border: 1px solid #1f2430;
            border-radius: 5px;
            padding: 5px;
            width: 100%;
            position: relative;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            box-shadow: 0 2px 6px rgba(0,0,0,0.2);
            transition: transform 0.15s;
            overflow: hidden;
        }

        /* 60% Card Height Image Container Slot */
        .ftf-card-img-wrapper {
            height: 120px;
            background: #0f1117;
            border-radius: 4px;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            border: 1px solid #1a1e26;
            margin-bottom: 5px;
            position: relative;
        }

        .ftf-card-img-wrapper img {
            width: 100%;
            height: 100%;
            max-width: 100px;
            max-height: 100px;
            object-fit: contain;
            display: block;
            margin: 0 auto;
        }

        .txt-posicao-automatica {
            position: absolute;
            top: 4px;
            left: 4px;
            background: rgba(15, 17, 23, 0.85);
            color: #64748b;
            font-weight: 800;
            border-radius: 3px;
            font-size: 9px;
            padding: 1px 4px;
            border: 1px solid #232836;
            z-index: 2;
        }

        .ftf-card-info {
            display: flex;
            flex-direction: column;
            text-align: left;
            padding: 1px 2px;
        }

        .ftf-item-name {
            margin: 0;
            font-size: 11.5px;
            font-weight: 700;
            color: #ffffff;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            line-height: 1.2;
        }

        .ftf-item-rarity {
            font-size: 8px;
            font-weight: 700;
            text-transform: uppercase;
            margin-top: 1px;
            margin-bottom: 4px;
            letter-spacing: 0.3px;
        }

        /* Core Values Layout Elements Split */
        .ftf-value-row {
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
            margin-bottom: 4px;
        }

        .ftf-value-label {
            font-size: 7px;
            color: #475569;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.3px;
        }

        .box-valor-dinamico {
            font-size: 16px;
            font-weight: 900;
            color: #ffb830;
            line-height: 1;
            display: flex;
            align-items: center;
            gap: 2px;
        }

        .txt-estabilidade {
            display: flex;
            align-items: center;
            gap: 3px;
            padding: 2px 4px;
            border-radius: 3px;
            font-size: 8px;
            font-weight: 700;
            background: #161a24;
            border: 1px solid #222938;
            height: 16px;
        }

        .txt-estabilidade svg {
            width: 10px;
            height: 10px;
            flex: none;
        }

        /* Status & Demand Rows */
        .box-badge-status {
            display: flex;
            justify-content: flex-start;
            margin-bottom: 4px;
            min-height: 12px;
        }

        .ftf-badge {
            font-size: 7px;
            font-weight: 800;
            padding: 1px 4px;
            border-radius: 2px;
            text-transform: uppercase;
            display: flex;
            align-items: center;
            gap: 2px;
        }

        .ftf-demand-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-top: 1px solid #1a1e26;
            padding-top: 4px;
            margin-top: 2px;
        }

        .txt-demanda-estrelas {
            display: flex;
            gap: 0.5px;
            align-items: center;
        }

        /* Action Configuration Controls Layer */
        .btn-acoes-card {
            margin-top: 5px;
            display: flex;
            flex-direction: column;
            gap: 3px;
            border-top: 1px dashed #232836;
            padding-top: 4px;
        }

        .btn-acoes-card-row {
            display: flex;
            gap: 3px;
        }

        .btn-acoes-card button {
            background: #1c202b;
            color: #94a3b8;
            border: 1px solid #282f40;
            font-size: 9px;
            padding: 3px;
            border-radius: 3px;
            cursor: pointer;
            font-weight: 600;
        }

        .btn-acoes-card button:hover {
            background: #282f40;
            color: #fff;
        }

        .btn-deletar {
            position: absolute;
            top: 4px;
            right: 4px;
            background: rgba(15,17,23,0.8);
            border: 1px solid #232836;
            color: #ef4444;
            font-size: 8px;
            width: 14px;
            height: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 3px;
            cursor: pointer;
            z-index: 10;
        }

        /* High Compact Print Mode (Forced 16 Col Grid View) */
        .hide-mode .ftf-header,
        .hide-mode #criador-form,
        .hide-mode .btn-aba-container,
        .hide-mode #btn-exportar-container,
        .hide-mode #search-container,
        .hide-mode .btn-deletar,
        .hide-mode .btn-acoes-card,
        .hide-mode #btn-limpar-tudo,
        .hide-mode .subtabs-container,
        .hide-mode .event-filter-wrapper,
        .hide-mode .event-filter-container,
        .hide-mode .toolbar-container { display: none !important; }

        .hide-mode #container-cards {
            grid-template-columns: repeat(16, 1fr) !important;
            width: 100% !important;
            max-width: 100% !important;
            gap: 4px !important;
        }

        .hide-mode .ftf-item-card {
            padding: 3px !important;
        }

        .hide-mode .ftf-card-img-wrapper {
            height: 75px !important;
        }

        .hide-mode .ftf-item-name {
            font-size: 9px !important;
        }

        .hide-mode .box-valor-dinamico {
            font-size: 12px !important;
        }

        .hide-mode .txt-estabilidade {
            font-size: 6.5px !important;
            padding: 1px 2px !important;
            height: 12px !important;
        }

        .ocultar-controles-cards .btn-acoes-card,
        .ocultar-controles-cards .btn-deletar {
            display: none !important;
        }

        /* Utilities */
        hr {
            display: none;
        }

        #btn-exportar-container {
            max-width: 1300px;
            margin: 0 auto 12px auto;
            text-align: right;
        }

        /* Mobile Optimization Rules */
        @media (max-width: 640px) {
            #container-cards {
                grid-template-columns: repeat(3, 1fr);
                gap: 4px;
            }
            .ftf-header-logo h1 { font-size: 14px; }
            .ftf-nav-links { gap: 8px; }
            .ftf-nav-item { font-size: 11px; }
            .ftf-card-img-wrapper { height: 95px; }
        }
    </style>
</head>
<body id="capture-area">

    <div class="ftf-header">
        <div class="ftf-header-logo">
            <h1>FTF <span>VALUES</span></h1>
        </div>
        <div class="ftf-nav-links">
            <div class="ftf-nav-item" onclick="filtrarRaridade('legendary')">Marretas</div>
            <div class="ftf-nav-item" onclick="filtrarSubcategoria('bundles')">Bundles</div>
            <div class="ftf-nav-item active">Custom List</div>
        </div>
    </div>

    <div class="toolbar-container" id="toolbar-menu">
        <div>
            <button id="togglePrintBtn" class="ui-btn" onclick="togglePrintMode()">Modo Print</button>
            <button id="toggleControlesBtn" class="ui-btn" onclick="toggleControlesCards()">Ocultar Controles</button>
            <button class="ui-btn btn-salvar-galeria" onclick="salvarNaGaleria()">📥 Exportar Imagem</button>
        </div>
        <div>
            <button id="btn-limpar-tudo" class="ui-btn" style="border-color: #ef4444; color: #ef4444;" onclick="resetarParaPadraoCodigo()">Restaurar Valores Padrão</button>
        </div>
    </div>

    <div class="search-wrapper" id="search-container">
        <input type="text" id="barraPesquisa" class="input-style" placeholder="Search items..." oninput="carregarCardsSalvos()">
        <select id="ordenacaoLista" class="input-style" onchange="ordenarEAtualizar()">
            <option value="padrao">🔢 Ordem Padrão</option>
            <option value="valor-alto">📈 Value (High to Low)</option>
            <option value="valor-baixo">📉 Value (Low to High)</option>
            <option value="nome-az">🔤 Name (A-Z)</option>
            <option value="nome-za">🔤 Name (Z-A)</option>
        </select>
    </div>

    <div id="criador-form">
        <div class="form-tabs">
            <button class="form-tab-btn active" id="tab-unico" onclick="mudarAbaForm('unico')">Individual Card</button>
            <button class="form-tab-btn" id="tab-massa" onclick="mudarAbaForm('massa')">Adicionar Links Extra (Massa)</button>
        </div>

        <div id="form-individual" class="form-section">
            <div class="form-grid">
                <div class="form-group">
                    <label class="form-label">Nome do Item</label>
                    <input type="text" id="nomeItem" class="input-style" placeholder="Ex: Cookie Mallet">
                </div>
                <div class="form-group">
                    <label class="form-label">Link da Imagem URL</label>
                    <input type="text" id="linkImagem" class="input-style" placeholder="https://i.postimg.cc/...">
                </div>
                <div class="form-group">
                    <label class="form-label">Valor (FV)</label>
                    <input type="text" id="valorItem" class="input-style" placeholder="Ex: 45">
                </div>
                <div class="form-group">
                    <label class="form-label">Evento</label>
                    <input type="text" id="eventoItem" class="input-style" placeholder="Ex: Halloween, Christmas">
                </div>
                <div class="form-group">
                    <label class="form-label">Raridade</label>
                    <select id="raridadeItem" class="input-style">
                        <option value="legendary">👑 Legendary</option>
                        <option value="epics">✨ Epic</option>
                        <option value="rares">💎 Rare</option>
                        <option value="commons">🍃 Common</option>
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label">Sub-Category Tier Tipo</label>
                    <select id="tipoItem" class="input-style">
                        <option value="normal">Normal (Com Gema/Par)</option>
                        <option value="unique">Unique (Sem Gema ou Sem Marreta)</option>
                        <option value="bundles">Bundles (Duplas, Trios, Sub-marretas)</option>
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label">Item Novo (Update Store)</label>
                    <select id="recenteItem" class="input-style">
                        <option value="nao" selected>Não</option>
                        <option value="sim">Sim (New Items)</option>
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label">Demanda (Stars)</label>
                    <select id="demandaNota" class="input-style">
                        <option value="5">5 ⭐️⭐️⭐️⭐️⭐️</option>
                        <option value="4.5">4.5</option>
                        <option value="4">4</option>
                        <option value="3.5">3.5</option>
                        <option value="3">3</option>
                        <option value="2.5">2.5</option>
                        <option value="2">2</option>
                        <option value="1.5">1.5</option>
                        <option value="1">1</option>
                        <option value="0.5">0.5</option>
                        <option value="0">0</option>
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label">Change in Value (Tendência)</label>
                    <select id="tendenciaValor" class="input-style">
                        <option value="none">Estável</option>
                        <option value="subiu">Subiu (↑ Verde)</option>
                        <option value="caiu">Caiu (↓ Vermelho)</option>
                        <option value="corrigido">Corrigido (* Amarelo)</option>
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label">Status Item Badge</label>
                    <select id="statusItem" class="input-style">
                        <option value="none">Nenhum</option>
                        <option value="overpaid">Overpaid For</option>
                        <option value="underpaid">Underpaid For</option>
                        <option value="niche">Niche</option>
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label">Item Stability</label>
                    <select id="estabilidadeItem" class="input-style">
                        <option value="Rising">Rising</option>
                        <option value="Doing Well">Doing Well</option>
                        <option value="Improving">Improving</option>
                        <option value="Stable" selected>Stable</option>
                        <option value="Fluctuating">Fluctuating</option>
                        <option value="Struggling">Struggling</option>
                        <option value="Receding">Receding</option>
                        <option value="Dropping">Dropping</option>
                    </select>
                </div>
            </div>
            <button type="button" class="btn-submit" onclick="criarNovoCard()">Adicionar Item Customizado ✨</button>
        </div>

