                <label style="color:#64748b; font-size:10px; font-weight:700; display:block; margin: 6px 0 2px 0;">ITEM NAME:</label>
                <input type="text" id="edit-nome" class="input-style" style="width:100%; margin-bottom:8px;" value="${item.nome || ''}">

                <label style="color:#64748b; font-size:10px; font-weight:700; display:block; margin: 6px 0 2px 0;">IMAGE URL:</label>
                <input type="text" id="edit-img" class="input-style" style="width:100%; margin-bottom:8px;" value="${item.imgSrc || ''}">

                <label style="color:#64748b; font-size:10px; font-weight:700; display:block; margin: 6px 0 2px 0;">VALUE (FV):</label>
                <input type="text" id="edit-valor" class="input-style" style="width:100%; margin-bottom:8px;" value="${item.valor || ''}">

                <label style="color:#64748b; font-size:10px; font-weight:700; display:block; margin: 6px 0 2px 0;">EVENT CATEGORY:</label>
                <input type="text" id="edit-evento" class="input-style" style="width:100%; margin-bottom:8px;" value="${item.evento || 'Geral'}">

                <label style="color:#64748b; font-size:10px; font-weight:700; display:block; margin: 6px 0 2px 0;">RARITY TIER:</label>
                <select id="edit-raridade" class="input-style" style="width:100%; margin-bottom:8px;">
                    <option value="legendary" ${item.raridade === 'legendary'?'selected':''}>👑 Legendary</option>
                    <option value="epics" ${item.raridade === 'epics'?'selected':''}>✨ Epic</option>
                    <option value="rares" ${item.raridade === 'rares'?'selected':''}>💎 Rare</option>
                    <option value="commons" ${item.raridade === 'commons'?'selected':''}>🍃 Common</option>
                </select>

                <label style="color:#64748b; font-size:10px; font-weight:700; display:block; margin: 6px 0 2px 0;">SUB-CATEGORY TYPE:</label>
                <select id="edit-tipo" class="input-style" style="width:100%; margin-bottom:8px;">
                    <option value="normal" ${item.tipo === 'normal'?'selected':''}>Normal (Com Gema/Par)</option>
                    <option value="unique" ${item.tipo === 'unique'?'selected':''}>Unique (Sem Gema ou Sem Marreta)</option>
                    <option value="bundles" ${item.tipo === 'bundles'?'selected':''}>Bundles</option>
                </select>

                <label style="color:#64748b; font-size:10px; font-weight:700; display:block; margin: 6px 0 2px 0;">NEW ITEMS LISTING?</label>
                <select id="edit-recente" class="input-style" style="width:100%; margin-bottom:8px;">
                    <option value="nao" ${item.recente === 'nao'?'selected':''}>Não</option>
                    <option value="sim" ${item.recente === 'sim'?'selected':''}>Sim (New Items)</option>
                </select>

                <label style="color:#64748b; font-size:10px; font-weight:700; display:block; margin: 6px 0 2px 0;">DEMAND RATE:</label>
                <select id="edit-demanda" class="input-style" style="width:100%; margin-bottom:8px;">
                    ${[5, 4.5, 4, 3.5, 3, 2.5, 2, 1.5, 1, 0.5, 0].map(v => `<option value="${v}" ${parseFloat(item.demanda) === v ? 'selected':''}>${v}</option>`).join('')}
                </select>

                <label style="color:#64748b; font-size:10px; font-weight:700; display:block; margin: 6px 0 2px 0;">CHANGE VALUE ARROW:</label>
                <select id="edit-tendencia" class="input-style" style="width:100%; margin-bottom:8px;">
                    <option value="none" ${item.tendencia === 'none'?'selected':''}>Estável</option>
                    <option value="subiu" ${item.tendencia === 'subiu'?'selected':''}>Subiu (↑)</option>
                    <option value="caiu" ${item.tendencia === 'caiu'?'selected':''}>Caiu (↓)</option>
                    <option value="corrigido" ${item.tendencia === 'corrigido'?'selected':''}>Corrigido (*)</option>
                </select>

                <label style="color:#64748b; font-size:10px; font-weight:700; display:block; margin: 6px 0 2px 0;">MARKET STATUS BADGE:</label>
                <select id="edit-status" class="input-style" style="width:100%; margin-bottom:8px;">
                    <option value="none" ${item.status === 'none'?'selected':''}>Nenhum</option>
                    <option value="overpaid" ${item.status === 'overpaid'?'selected':''}>Overpaid For</option>
                    <option value="underpaid" ${item.status === 'underpaid'?'selected':''}>Underpaid For</option>
                    <option value="niche" ${item.status === 'niche'?'selected':''}>Niche</option>
                </select>

                <label style="color:#64748b; font-size:10px; font-weight:700; display:block; margin: 6px 0 2px 0;">STABILITY STATUS:</label>
                <select id="edit-estabilidade" class="input-style" style="width:100%; margin-bottom:12px;">
                    ${["Rising","Doing Well","Improving","Stable","Fluctuating","Struggling","Receding","Dropping"].map(est => `<option value="${est}" ${item.templates === est ? 'selected':''}>${est}</option>`).join('')}
                </select>

                <div style="display: flex; gap: 8px;">
                    <button id="modal-cancelar" style="flex:1; padding:8px; background:#222733; color:#fff; border:1px solid #2d3445; border-radius:4px; font-weight:600; cursor:pointer;">Cancel</button>
                    <button id="modal-salvar" style="flex:1; padding:8px; background:#ffb830; color:#000; border:none; border-radius:4px; font-weight:700; cursor:pointer;">Save Changes</button>
                </div>
            </div>
        `;

        document.body.appendChild(modal);
        document.getElementById('modal-cancelar').onclick = () => modal.remove();
        document.getElementById('modal-salvar').onclick = () => {
            item.nome = document.getElementById('edit-nome').value.trim() || item.nome;
            item.imgSrc = document.getElementById('edit-img').value.trim();
            item.valor = document.getElementById('edit-valor').value.trim();
            item.evento = document.getElementById('edit-evento').value.trim() || 'Geral';
            item.raridade = document.getElementById('edit-raridade').value;
            item.tipo = document.getElementById('edit-tipo').value;
            item.recente = document.getElementById('edit-recente').value;
            item.demanda = document.getElementById('edit-demanda').value;
            item.tendencia = document.getElementById('edit-tendencia').value;
            item.status = document.getElementById('edit-status').value;
            item.templates = document.getElementById('edit-estabilidade').value;

            localStorage.setItem('ftf_custom_v5', JSON.stringify(listaDeMarretas));
            atualizarFiltroEventosMenu();
            carregarCardsSalvos();
            modal.remove();
        };
    }

    function renderizarCardHTML(item) {
        const container = document.getElementById('container-cards');
        const card = document.createElement("div");
        card.className = "ftf-item-card";

        const raridadeKey = (item.raridade || 'legendary').toLowerCase();
        const corRaridade = CORES_RARIDADE[raridadeKey] || '#2d3545';
        card.setAttribute('data-id', item.id);

        const caminhoImagem = item.imgSrc || 'https://placehold.co/150x110/0f1117/ffffff?text=No+Image';
        const estabilidadeTexto = item.templates || 'Stable';
        const corEstabilidade = CORES_ESTABILIDADE[estabilidadeTexto.toLowerCase().trim()] || '#94a3b8';

        card.innerHTML = `
            <button class="btn-deletar">✕</button>
            <div class="ftf-card-img-wrapper">
                <span class="txt-posicao-automatica">#--</span>
                <img src="${caminhoImagem}" loading="lazy" alt="${item.nome}" onerror="this.src='https://placehold.co/150x110/0f1117/ffffff?text=No+Image'">
            </div>
            <div class="ftf-card-info">
                <h3 class="ftf-item-name">${item.nome}</h3>
                <span class="ftf-item-rarity" style="color: ${corRaridade};">${item.raridade}</span>
                
                <div class="ftf-value-row">
                    <div>
                        <div class="ftf-value-label">Value</div>
                        <span class="box-valor-dinamico"></span>
                    </div>
                    <span class="txt-estabilidade" style="color: ${corEstabilidade};">
                        ${SVG_ESTABILIDADE[estabilidadeTexto] || ""}
                        <span>${estabilidadeTexto}</span>
                    </span>
                </div>

                <div class="box-badge-status"></div>

                <div class="ftf-demand-row">
                    <span class="ftf-value-label">Demand</span>
                    <span class="txt-demanda-estrelas"></span>
                </div>

                <div class="btn-acoes-card">
                    <div class="btn-acoes-card-row">
                        <button class="btn-subir" style="flex:1;">▲</button>
                        <button class="btn-descer" style="flex:1;">▼</button>
                    </div>
                    <button class="btn-editar">✏️ Edit Parameters</button>
                </div>
            </div>
        `;

        card.querySelector('.btn-editar').addEventListener('click', () => abrirModalEdicaoCompleta(item));
        card.querySelector('.btn-deletar').addEventListener('click', () => {
            if (confirm(`Excluir item "${item.nome}"?`)) {
                listaDeMarretas = listaDeMarretas.filter(m => m.id !== item.id);
                card.remove();
                localStorage.setItem('ftf_custom_v5', JSON.stringify(listaDeMarretas));
                carregarCardsSalvos();
            }
        });

        card.querySelector('.btn-subir').addEventListener('click', () => {
            const ant = card.previousElementSibling;
            if (ant) { container.insertBefore(card, ant); reordenarArrayEGuardar(); }
        });

        card.querySelector('.btn-descer').addEventListener('click', () => {
            const prox = card.nextElementSibling;
            if (prox) { container.insertBefore(prox, card); reordenarArrayEGuardar(); }
        });

        atualizarEstiloValorDoCard(card, item);
        gerarEstrelasDemanda(card, item.demanda);
        return card;
    }

    function filtrarRaridade(raridadeAlvo) {
        raridadeAtual = raridadeAlvo;
        definirAbaAtivaVisual(raridadeAlvo);

        let datasSalvas = JSON.parse(localStorage.getItem('ftf_datas_att')) || {};
        document.getElementById('input-data-att').value = datasSalvas[raridadeAtual] || "July 4th, 2026";

        carregarCardsSalvos();
    }

    function definirAbaAtivaVisual(raridadeAlvo) {
        document.querySelectorAll('.btn-aba').forEach(btn => btn.classList.remove('active'));
        const botaoAtivo = document.getElementById('aba-' + raridadeAlvo);
        if (botaoAtivo) botaoAtivo.classList.add('active');
        document.getElementById('titulo-secao').innerText = `${raridadeAlvo.toUpperCase()} ITEMS`;
    }

        function atualizarEstiloValorDoCard(cardHTML, item) {
        const containerValor = cardHTML.querySelector('.box-valor-dinamico');
        const containerBadge = cardHTML.querySelector('.box-badge-status');
        if (!containerValor) return;

        let badgeTendencia = '';
        let valorExibido = item.valor || "10";
        let corDinamica = '#ffb830'; // Cor padrão amarela do FTF

        // Define a mesma cor para o valor e para a seta com base na tendência
        if (item.tendencia === 'subiu') { 
            corDinamica = '#47cc6a'; // Verde
            badgeTendencia = ` <span>↑</span>`; 
        }
        else if (item.tendencia === 'caiu') { 
            corDinamica = '#ff4d4f'; // Vermelho
            badgeTendencia = ` <span>↓</span>`; 
        }
        else if (item.tendencia === 'corrigido') { 
            corDinamica = '#f2be24'; // Amarelo de correção
            badgeTendencia = ` <span>*</span>`; 
        }
        
        // Aplica a cor diretamente no container que junta valor + seta
        containerValor.style.color = corDinamica;
        containerValor.innerHTML = `${valorExibido}${badgeTendencia}`;

        if (containerBadge) {
            containerBadge.innerHTML = '';
            if (item.status === 'overpaid') containerBadge.innerHTML = `<span class="ftf-badge" style="color: #47cc6a; background: rgba(71,204,106,0.1); border: 1px solid rgba(71,204,106,0.2);">Overpaid For</span>`;
            else if (item.status === 'underpaid') containerBadge.innerHTML = `<span class="ftf-badge" style="color: #ff4d4f; background: rgba(255,77,79,0.1); border: 1px solid rgba(255,77,79,0.2);">Underpaid For</span>`;
            else if (item.status === 'niche') containerBadge.innerHTML = `<span class="ftf-badge" style="color: #45aaf2; background: rgba(69,170,242,0.1); border: 1px solid rgba(69,170,242,0.2);">Niche</span>`;
        }
    }


    function gerarEstrelasDemanda(cardHTML, notaEstrelas) {
        const containerEstrelas = cardHTML.querySelector('.txt-demanda-estrelas');
        if (!containerEstrelas) return;
        
        let notaNum = parseFloat(notaEstrelas) || 0;
        let estrelasHTML = '';
        const TAMANHO_ESTRELA = '9px'; 

        const svgEstrelaCheia = `<svg viewBox="0 0 24 24" style="width:${TAMANHO_ESTRELA}; height:${TAMANHO_ESTRELA}; fill:#ffb830;"><path d="M12 .587l3.668 7.431 8.2 1.192-5.934 5.784 1.4 8.168L12 18.896l-7.334 3.857 1.4-8.168L.133 9.21l8.2-1.192z"/></svg>`;
        const svgEstrelaVazia = `<svg viewBox="0 0 24 24" style="width:${TAMANHO_ESTRELA}; height:${TAMANHO_ESTRELA}; fill:none; stroke:#334155; stroke-width:3;"><path d="M12 .587l3.668 7.431 8.2 1.192-5.934 5.784 1.4 8.168L12 18.896l-7.334 3.857 1.4-8.168L.133 9.21l8.2-1.192z"/></svg>`;
for (let i = 1; i <= 5; i++) {
    if (notaNum >= i) {
        estrelasHTML += svgEstrelaCheia;
    } else if (notaNum > i - 1 && notaNum < i) {
        estrelasHTML += `
            <span style="display:inline-block; position:relative; width:${TAMANHO_ESTRELA}; height:${TAMANHO_ESTRELA}; vertical-align: middle;">
                <svg viewBox="0 0 24 24" style="position:absolute; top:0; left:0; width:100%; height:100%; fill:#334155;"><path d="M12 .587l3.668 7.431 8.2 1.192-5.934 5.784 1.4 8.168L12 18.896l-7.334 3.857 1.4-8.168L.133 9.21l8.2-1.192z"/></svg>
                
                <span style="position:absolute; top:0; left:0; width:50%; height:100%; overflow:hidden;">
                    <svg viewBox="0 0 24 24" style="width:${TAMANHO_ESTRELA}; height:${TAMANHO_ESTRELA}; fill:#ffb830; display:block;"><path d="M12 .587l3.668 7.431 8.2 1.192-5.934 5.784 1.4 8.168L12 18.896l-7.334 3.857 1.4-8.168L.133 9.21l8.2-1.192z"/></svg>
                </span>
            </span>
        `;
    } else {
        estrelasHTML += svgEstrelaVazia;
    }
 }
containerEstrelas.innerHTML = estrelasHTML;

}
        
    function ordenarEAtualizar() {
        const criterio = document.getElementById('ordenacaoLista').value;

        if (criterio === 'nome-az') {
            listaDeMarretas.sort((a, b) => (a.nome || "").localeCompare(b.nome || ""));
        } 
        else if (criterio === 'nome-za') {
            listaDeMarretas.sort((a, b) => (b.nome || "").localeCompare(a.nome || ""));
        } 
        else if (criterio === 'valor-alto') {
            listaDeMarretas.sort((a, b) => {
                const valA = parseFloat((a.valor || "0").toString().replace(/[^0-9.]/g, '')) || 0;
                const valB = parseFloat((b.valor || "0").toString().replace(/[^0-9.]/g, '')) || 0;
                return valB - valA;
            });
        } 
        else if (criterio === 'valor-baixo') {
            listaDeMarretas.sort((a, b) => {
                const valA = parseFloat((a.valor || "0").toString().replace(/[^0-9.]/g, '')) || 0;
                const valB = parseFloat((b.valor || "0").toString().replace(/[^0-9.]/g, '')) || 0;
                return valA - valB;
            });
        } 
        else if (criterio === 'padrao') {
            inicializarBancoDados();
            return;
        }

        localStorage.setItem('ftf_custom_v5', JSON.stringify(listaDeMarretas));
        carregarCardsSalvos();
    }

    function carregarCardsSalvos() {
        const container = document.getElementById('container-cards');
        if (!container) return;

        const termoPesquisa = document.getElementById('barraPesquisa').value.toLowerCase();

        const itensFiltrados = listaDeMarretas.filter(item => {
            const raridadeItem = (item.raridade || 'legendary').toLowerCase();
            const bateRaridade = raridadeItem === raridadeAtual.toLowerCase();
            const bateNome = (item.nome || "").toLowerCase().includes(termoPesquisa);
            const bateEvento = eventoAtual === 'all' || item.evento === eventoAtual;
            
            if (!bateRaridade || !bateNome || !bateEvento) return false;

            const valorNum = parseFloat((item.valor || "0").toString().replace(/[^0-9.]/g, '')) || 0;
            if (subcategoriaAtual === 'recentes' && item.recente !== 'sim') return false;
            if (subcategoriaAtual === 'unicos' && item.tipo !== 'unique') return false;
            if (subcategoriaAtual === 'bundles' && item.tipo !== 'bundles') return false;
            if (subcategoriaAtual === 'high' && valorNum < 90) return false;
            if (subcategoriaAtual === 'mid' && (valorNum < 30 || valorNum >= 90)) return false;
            if (subcategoriaAtual === 'low' && (valorNum < 1 || valorNum >= 30)) return false;

            return true;
        });

        document.getElementById('dash-qtd').innerText = itensFiltrados.length;
        const totalValorCalculado = itensFiltrados.reduce((acc, obj) => {
            const v = parseFloat((obj.valor || "0").toString().replace(/[^0-9.]/g, '')) || 0;
            return acc + v;
        }, 0);
        document.getElementById('dash-valor').innerText = totalValorCalculado;

        container.innerHTML = '';
        const fragment = document.createDocumentFragment();

        itensFiltrados.forEach(item => {
            const card = renderizarCardHTML(item); 
            if (card) fragment.appendChild(card);
        });

        container.appendChild(fragment);
        atualizarNumbersVisuais();
    }

    function reordenarArrayEGuardar() {
        let listaLimpa = listaDeMarretas.filter(item => (item.raridade || 'legendary') !== raridadeAtual);
        let itensReordenadosDaAba = [];

        document.querySelectorAll('#container-cards .ftf-item-card').forEach((cardHTML) => {
            const id = parseInt(cardHTML.getAttribute('data-id'));
            const correspondente = listaDeMarretas.find(m => m.id === id);
            if (correspondente) itensReordenadosDaAba.push(correspondente);
        });
        
        listaDeMarretas = [...listaLimpa, ...itensReordenadosDaAba];
        localStorage.setItem('ftf_custom_v5', JSON.stringify(listaDeMarretas));
        atualizarNumbersVisuais();
    }

    function atualizarNumbersVisuais() {
        document.querySelectorAll('#container-cards .ftf-item-card').forEach((cardHTML, index) => {
            const caixaTextoPosicao = cardHTML.querySelector('.txt-posicao-automatica');
            if (caixaTextoPosicao) caixaTextoPosicao.innerText = `#${index + 1}`;
        });
    }

    function exportarLista() {
        navigator.clipboard.writeText(JSON.stringify(listaDeMarretas, null, 2)).then(() => {
            alert("Backup copiado!");
        });
    }

    window.onload = inicializarBancoDados;
</script>
</body>
