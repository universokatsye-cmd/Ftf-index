    let listaDeMarretas = [];
    let raridadeAtual = 'legendary'; 
    let subcategoriaAtual = 'todos';
    let eventoAtual = 'all';
    
    function inicializarBancoDados() {
        let dadosLocais = null;
        try {
            dadosLocais = JSON.parse(localStorage.getItem('ftf_custom_v5'));
        } catch (e) {
            dadosLocais = null;
        }

        if (!Array.isArray(dadosLocais) || dadosLocais.length === 0) {
            listaDeMarretas = [];
            forçarInjecaoListaPadrao();
        } else {
            listaDeMarretas = dadosLocais.map(item => ({
                id: item.id,
                nome: item.nome || "Marreta",
                valor: item.valor || '10',  
                raridade: item.raridade || 'legendary',
                demanda: item.demanda || '5', 
                tendencia: item.tendencia || 'none',
                status: item.status || 'none',
                templates: item.templates || 'Stable',
                imgSrc: item.imgSrc,
                evento: item.evento || mapearEventoAutomatico(item.nome),
                tipo: item.tipo || 'normal',
                recente: item.recente || 'nao'
            }));
        }

        localStorage.setItem('ftf_custom_v5', JSON.stringify(listaDeMarretas));
        
        let datasSalvas = JSON.parse(localStorage.getItem('ftf_datas_att')) || {};
        document.getElementById('input-data-att').value = datasSalvas[raridadeAtual] || "July 4th, 2026";

        atualizarFiltroEventosMenu();
        configurarBotoesEvento();
        carregarCardsSalvos();
    }

    function forçarInjecaoListaPadrao() {
        listaDeMarretas = BASE_PADRAO_MARRETAS.map(m => ({
            id: m.id,
            nome: m.nome || "Marreta",
            valor: m.valor || '10',  
            raridade: m.raridade || 'legendary',
            demanda: m.demanda || '5', 
            tendencia: m.tendencia || 'none',
            status: m.status || 'none',
            templates: m.templates || 'Stable',
            imgSrc: m.imgSrc,
            evento: mapearEventoAutomatico(m.nome),
            tipo: m.tipo || 'normal',
            recente: 'nao'
        }));
        localStorage.setItem('ftf_custom_v5', JSON.stringify(listaDeMarretas));
    }

        function mapearEventoAutomatico(nome) {
    const n = (nome || "").toLowerCase();
    
    if (n.includes('lunar') || n.includes('ox') || n.includes('tiger') || n.includes('rat')) return 'Lunar New Year';
    if (n.includes('valentine') || n.includes('heart') || n.includes('love') || n.includes('cupid')) return 'Valentines';
    if (n.includes('patrick') || n.includes('clover') || n.includes('shamrock') || n.includes('leprechaun')) return 'Saint Patrick';
    if (n.includes('spring') || n.includes('pegasus') || n.includes('bloom')) return 'Spring';
    if (n.includes('easter') || n.includes('bunny') || n.includes('chick') || n.includes('egg')) return 'Easter';
    if (n.includes('anniversary') || n.includes('2nd') || n.includes('3rd') || n.includes('4th') || n.includes('5th') || n.includes('6th') || n.includes('7th') || n.includes('8th') || n.includes('balloons')) return 'Anniversary';
    if (n.includes('summer') || n.includes('beach') || n.includes('sundae') || n.includes('anchor')) return 'Summer';
    if (n.includes('autumn') || n.includes('fall') || n.includes('crops') || n.includes('maple')) return 'Fall';
    if (n.includes('halloween') || n.includes('spook') || n.includes('witch') || n.includes('zombie') || n.includes('pumpkin')) return 'Halloween';
    if (n.includes('santa') || n.includes('christmas') || n.includes('winter') || n.includes('snow') || n.includes('ice')) return 'Winter';
    
    return 'Geral';
}


    function resetarParaPadraoCodigo() {
        if (confirm("Deseja realmente restaurar todos os valores oficiais padrão do FTF Values?")) {
            localStorage.removeItem('ftf_custom_v5');
            localStorage.removeItem('ftf_datas_att');
            forçarInjecaoListaPadrao();
            inicializarBancoDados();
        }
    }

