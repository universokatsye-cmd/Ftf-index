    function atualizarFiltroEventosMenu() {
        const select = document.getElementById('filtroEvento');
        if (!select) return;
        const eventosUnicos = [...new Set(listaDeMarretas.map(item => item.evento || "Geral"))];
        
        select.innerHTML = '<option value="todos">🌍 Todos os Eventos</option>';
        eventosUnicos.sort().forEach(ev => {
            select.innerHTML += `<option value="${ev}">${ev}</option>`;
        });
    }

    // FIX: conecta os botões de evento (.event-btn) que já existiam no HTML
    // mas nunca tinham um listener de clique associado.
    function configurarBotoesEvento() {
        document.querySelectorAll('.event-btn').forEach(btn => {
            if (btn.dataset.bound === '1') return; // evita duplicar listeners
            btn.dataset.bound = '1';
            btn.addEventListener('click', () => {
                document.querySelectorAll('.event-btn').forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
                eventoAtual = btn.getAttribute('data-event') || 'all';
                carregarCardsSalvos();
            });
        });
    }

    function mudarAbaForm(aba) {
        document.getElementById('tab-unico').classList.remove('active');
        document.getElementById('tab-massa').classList.remove('active');
        document.getElementById('form-individual').style.display = 'none';
        document.getElementById('form-massa').style.display = 'none';

        if(aba === 'unico') {
            document.getElementById('tab-unico').classList.add('active');
            document.getElementById('form-individual').style.display = 'block';
        } else {
            document.getElementById('tab-massa').classList.add('active');
            document.getElementById('form-massa').style.display = 'block';
        }
    }

    function importarLinksEmMassa() {
        const campoTexto = document.getElementById('listaLinksMassa').value;
        if(!campoTexto.trim()) return;

        const regexLinks = /(https?:\/\/[^\s]+)/g;
        const linksEncontrados = campoTexto.match(regexLinks);

        if(!linksEncontrados) return;

        linksEncontrados.forEach((url, i) => {
            const novoObj = { 
                id: Date.now() + i + Math.floor(Math.random() * 9000), 
                nome: `Imported Item ${listaDeMarretas.length + 1}`, 
                valor: '10', 
                raridade: raridadeAtual, 
                demanda: '5', 
                tendencia: 'none', 
                status: 'none', 
                templates: 'Stable', 
                imgSrc: url.trim(),
                evento: 'Geral',
                tipo: 'normal',
                recente: 'nao'
            };
            listaDeMarretas.push(novoObj);
        });

        localStorage.setItem('ftf_custom_v5', JSON.stringify(listaDeMarretas));
        atualizarFiltroEventosMenu();
        carregarCardsSalvos();
        document.getElementById('listaLinksMassa').value = '';
    }

