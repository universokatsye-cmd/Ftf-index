    function salvarNaGaleria() {
        const jaEstavaEmPrint = document.body.classList.contains('hide-mode');
        if (!jaEstavaEmPrint) {
            document.body.classList.add('hide-mode');
            carregarCardsSalvos();
        }

        setTimeout(() => {
            const areaCaptura = document.getElementById('capture-area');
            html2canvas(areaCaptura, {
                backgroundColor: "#0f1117",
                useCORS: true, 
                scale: 2,
                windowWidth: 1400
            }).then(canvas => {
                const link = document.createElement('a');
                link.download = `FTF-Values-${raridadeAtual}.png`;
                link.href = canvas.toDataURL('image/png');
                link.click();

                if (!jaEstavaEmPrint) {
                    document.body.classList.remove('hide-mode');
                    carregarCardsSalvos();
                }
            }).catch(err => {
                if (!jaEstavaEmPrint) {
                    document.body.classList.remove('hide-mode');
                    carregarCardsSalvos();
                }
            });
        }, 400);
    }

    function criarNovoCard() {
        const nome = document.getElementById('nomeItem').value;
        const urlImagem = document.getElementById('linkImagem').value || 'https://via.placeholder.com/150';
        let valor = document.getElementById('valorItem').value || '10';
        const raridade = document.getElementById('raridadeItem').value;
        const demanda = document.getElementById('demandaNota').value;
        const tendencia = document.getElementById('tendenciaValor').value;
        const status = document.getElementById('statusItem').value;
        const estabilidade = document.getElementById('estabilidadeItem').value;
        const evento = document.getElementById('eventoItem').value || 'Geral';
        const tipo = document.getElementById('tipoItem').value;
        const recente = document.getElementById('recenteItem').value;

        if (!nome) return;

        const novoObj = { 
            id: Date.now(), 
            nome: nome, 
            valor: valor.toString().trim(), 
            raridade: raridade || 'legendary', 
            demanda: demanda, 
            tendencia: tendencia, 
            status: status, 
            templates: estabilidade, 
            imgSrc: urlImagem,
            evento: evento,
            tipo: tipo,
            recente: recente
        };
        
        listaDeMarretas.push(novoObj);
        localStorage.setItem('ftf_custom_v5', JSON.stringify(listaDeMarretas));
        
        raridadeAtual = raridade;
        definirAbaAtivaVisual(raridade);
        atualizarFiltroEventosMenu();
        carregarCardsSalvos();

        document.getElementById('nomeItem').value = '';
        document.getElementById('linkImagem').value = '';
        document.getElementById('valorItem').value = '';
        document.getElementById('eventoItem').value = '';
    }

